# Python API - .env olarak kopyalayın
OPENAI_API_KEY=
TAVILY_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
MONGODB_URI=

# AI Video (Pika - fal.ai) - varsa videoda ilk 5 sn gerçek AI video kullanılır
# https://fal.ai/dashboard/keys
FAL_KEY=

# Görsel API'leri (video için - Railway'da mutlaka ekleyin)
# Pexels: https://www.pexels.com/api/key (ücretsiz 20K/ay)
PEXELS_API_KEY=
# Unsplash: https://unsplash.com/oauth/applications (ücretsiz 5K/saat) - Pexels boşsa fallback
UNSPLASH_ACCESS_KEY=

# Railway: Python API public URL (video linkleri için)
PYTHON_PUBLIC_URL=https://primest-python-api-production.up.railway.app

# Next.js frontend URL (CORS için)
FRONTEND_URL=http://localhost:3000
